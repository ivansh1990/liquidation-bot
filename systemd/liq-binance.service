[Unit]
Description=Liquidation Bot - Binance Collector
After=network-online.target

[Service]
Type=oneshot
User=ivan
WorkingDirectory=/home/ivan/liquidation-bot
ExecStart=/home/ivan/liquidation-bot/.venv/bin/python -m collectors.binance_collector
EnvironmentFile=/home/ivan/liquidation-bot/.env
TimeoutStartSec=120
StandardOutput=journal
StandardError=journal
SyslogIdentifier=liq-binance
